{
  "name": "foma-render-engine",
  "displayName": "Foma Render Engine",
  "version": "1.0.0",
  "publisher": "FordiMalanda",
  "icon": "icons/foma-logo.svg",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "fre",
        "aliases": [
          "Foma Render Engine",
          "fre"
        ],
        "extensions": [
          ".fre"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fre",
        "scopeName": "text.html.handlebars",
        "path": "./syntaxes/fre.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "foma-icons",
        "label": "Foma Icons",
        "path": "./foma-icons.json"
      }
    ]
  },
  "repository": {
   "type": "git",
   "url": "https://github.com/fomadev/fre-extension"
}
}